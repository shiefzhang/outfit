    <style name="Theme.OutfitAI.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />
    <style name="Theme.OutfitAI.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />
</resources>
