<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 标题说明卡片 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🌟 场景穿搭建议"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="告诉 AI 你的穿搭场景，获取从头到脚的整体风格建议"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:lineSpacingMultiplier="1.4" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 场景输入 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_scene"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="描述您的场景（如：明天的公司年会、周末约会…）"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_scene"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minLines="3"
                        android:maxLines="5"
                        android:inputType="textMultiLine|textCapSentences"
                        android:gravity="top" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 风格偏好 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="风格偏好（可选）"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="16dp" />

                <!-- 日常休闲类 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌿 日常休闲类"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#444444"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="适用：逛街、出游、居家、通勤休闲"
                    android:textSize="11sp"
                    android:textColor="#999999"
                    android:layout_marginBottom="10dp" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_daily"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_korean_casual"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="韩系休闲"
                        style="@style/Widget.Material3.Chip.Filter" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_american_retro"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="美式复古"
                        style="@style/Widget.Material3.Chip.Filter" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_japanese_fresh"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="日系清新"
                        style="@style/Widget.Material3.Chip.Filter" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_active_sporty"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="活力运动"
                        style="@style/Widget.Material3.Chip.Filter" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_lazy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="慵懒风"
                        style="@style/Widget.Material3.Chip.Filter" />
                </com.google.android.material.chip.ChipGroup>

                <!-- 分割线 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginBottom="16dp" />

                <!-- 温柔气质类 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌸 温柔气质类"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#444444"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="适用：约会、下午茶、探店、轻聚会"
                    android:textSize="11sp"
                    android:textColor="#999999"
                    android:layout_marginBottom="10dp" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_gentle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_french_gentle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="法式温柔"
                        style="@style/Widget.Material3.Chip.Filter" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_pure_desire"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="纯欲风"
                        style="@style/Widget.Material3.Chip.Filter" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_sweet_girl"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="甜美少女风"
                        style="@style/Widget.Material3.Chip.Filter" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_warm_chinese"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="温婉国风"
                        style="@style/Widget.Material3.Chip.Filter" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_light_lady"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="轻淑女风"
                        style="@style/Widget.Material3.Chip.Filter" />
                </com.google.android.material.chip.ChipGroup>

                <!-- 分割线 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginBottom="16dp" />

                <!-- 干练职场 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💼 干练职场"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#444444"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="适用：上班、商务会面、正式场合"
                    android:textSize="11sp"
                    android:textColor="#999999"
                    android:layout_marginBottom="10dp" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_work"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_minimal_office"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="极简通勤风"
                        style="@style/Widget.Material3.Chip.Filter" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_mature_knowledge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="轻熟知性风"
                        style="@style/Widget.Material3.Chip.Filter" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_office_queen"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="职场御姐风"
                        style="@style/Widget.Material3.Chip.Filter" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_academic_office"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="学院通勤风"
                        style="@style/Widget.Material3.Chip.Filter" />
                </com.google.android.material.chip.ChipGroup>

                <!-- 分割线 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginBottom="16dp" />

                <!-- 酷飒个性类 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥 酷飒个性类"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#444444"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="适用：街头、看展、派对、个性出行"
                    android:textSize="11sp"
                    android:textColor="#999999"
                    android:layout_marginBottom="10dp" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_cool"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_cool_street"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="酷拽街头风"
                        style="@style/Widget.Material3.Chip.Filter" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_salt_cold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="盐系冷感风"
                        style="@style/Widget.Material3.Chip.Filter" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_motorcycle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="机车风"
                        style="@style/Widget.Material3.Chip.Filter" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_dark"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="暗黑系"
                        style="@style/Widget.Material3.Chip.Filter" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_workwear"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="工装风"
                        style="@style/Widget.Material3.Chip.Filter" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_baroque"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="巴洛克复古"
                        style="@style/Widget.Material3.Chip.Filter" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_boho"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="波西米亚风"
                        style="@style/Widget.Material3.Chip.Filter" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_pastoral"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="田园风"
                        style="@style/Widget.Material3.Chip.Filter" />
                </com.google.android.material.chip.ChipGroup>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 获取建议按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_get_suggestion"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="✨ 获取穿搭建议"
            android:textSize="17sp"
            android:textStyle="bold"
            app:cornerRadius="28dp"
            android:layout_marginBottom="20dp" />

        <!-- Loading -->
        <LinearLayout
            android:id="@+id/layout_loading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="16dp">

            <ProgressBar
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/analyzing"
                android:textColor="@color/purple_500"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- 结果卡片 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="👗 场景穿搭方案"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/tv_result"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="#444444"
                    android:lineSpacingMultiplier="1.5" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_save"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="💾 保存到穿搭历史"
                    android:textSize="13sp"
                    app:cornerRadius="20dp"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_marginTop="12dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <View
            android:layout_width="match_parent"
            android:layout_height="80dp" />

    </LinearLayout>
</ScrollView>
